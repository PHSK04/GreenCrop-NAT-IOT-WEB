# PostgreSQL / Neon connection
DATABASE_URL=
DB_SSL_MODE=
DB_SSL_REJECT_UNAUTHORIZED=false
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres

# JWT secret for signing test tokens (change in production)
JWT_SECRET=dev_jwt_secret

# Google Sign-In (backend token verification)
# Use web client ID, or comma-separated IDs in GOOGLE_CLIENT_IDS
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=

# Facebook Login (backend token verification)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# LINE Login (backend token verification/exchange)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=

# Microsoft Login (backend token verification/exchange)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=

# Sign in with Apple (backend token verification audience)
APPLE_BUNDLE_ID=
APPLE_SERVICE_ID=

# Other settings
NODE_ENV=development
# Shared tenant key (used only when SHARED_SENSOR_TENANT=true)
DEFAULT_TENANT_ID=public
# false = bind sensor stream by logged-in account (tenant_id from token)
SHARED_SENSOR_TENANT=false
# true = backend records ESP32 telemetry from smartfarm/sensors even when the web app is closed
ACCEPT_LEGACY_SENSOR_TOPIC=true
# Enable the dev JWT mint endpoint only for local development (set to 'true' to enable)
ENABLE_DEV_TOKEN=false

# NAT AI real conversation mode (server-side only, never expose this in frontend env)
# Python controller runs first and returns structured intent/risk/actions.
NAT_AI_PYTHON_ENABLED=true
NAT_AI_PYTHON_BIN=python3
NAT_AI_PYTHON_SCRIPT=ai/controller/nat_ai_controller.py
NAT_AI_PYTHON_TIMEOUT_MS=2500
# OpenAI remains the fallback/generative layer after the Python controller.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=180

# Allowed browser origins for CORS (comma-separated)
# Keep both local dev and GitHub Pages if you use both.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://phsk04.github.io
# localhost, 127.0.0.1, and [::1] are also allowed on any port for Flutter/Vite dev.
